{
  "functions": {
    "api/[...path].js": {
      "includeFiles": "server/schema.sql"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "headers": {
        "Permissions-Policy": "clipboard-read=(), clipboard-write=()"
      },
      "continue": true
    },
    { "src": "/api/(.*)", "dest": "/api/[...path].js" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
